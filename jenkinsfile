pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/kawinvb24/Week-2-K.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Start Metro (Test)') {
            steps {
                sh 'echo "Build Successful ✅"'
            }
        }
    }
}
